# ═══════════════════════════════════════════════════════════════════
# Massi-Bot — Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# Claude Code will walk you through each value when you run:
#   claude --dangerously-skip-permissions
# ═══════════════════════════════════════════════════════════════════

# ─── PLATFORM CHOICE ─────────────────────────────────────────────
# Which platform(s) to run: "fanvue", "onlyfans", or "both"
PLATFORM_MODE=fanvue

# Tier mode: "full" (tiers 1-6), "tease_only" (tiers 1-3), "gfe_only"
CONTENT_MODE=full

# ─── DOMAIN + SSL ────────────────────────────────────────────────
# Your domain for webhooks and OAuth (e.g., api.yourdomain.com)
# Must have an A record pointing to this VM's public IP
DOMAIN=

# ─── SUPABASE (Free Tier) ───────────────────────────────────────
# Create project at: https://supabase.com/dashboard
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=

# ─── SINGLE-AGENT ARCHITECTURE ──────────────────────────────────
# One Opus 4.7 call per fan message, plus Grok as an uncensor tool.
USE_SINGLE_AGENT=true
SINGLE_AGENT_MODEL=anthropic/claude-opus-4-7
UNCENSOR_MODEL=x-ai/grok-4-fast

# ─── LLM — OpenRouter ───────────────────────────────────────────
# Sign up at: https://openrouter.ai
# Add $50 credits to start (typical cost ~$0.008-0.015/message with Opus 4.7)
OPENROUTER_API_KEY=

# ─── EMBEDDING MODEL (optional) ─────────────────────────────────
# Default: BGE-M3 (1024-dim, ~570MB, strong retrieval quality)
# Smaller/faster alternative: sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_MODEL=BAAI/bge-m3

# ─── TELEGRAM ADMIN BOT ─────────────────────────────────────────
# Create bot via @BotFather on Telegram → /newbot
# Get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# ─── FANVUE (if PLATFORM_MODE is "fanvue" or "both") ────────────
# Register OAuth app at: https://fanvue.com/developers
# Redirect URI: https://{DOMAIN}/oauth/callback
FANVUE_CLIENT_ID=
FANVUE_CLIENT_SECRET=
FANVUE_APP_ID=
FANVUE_WEBHOOK_SECRET=
FANVUE_API_VERSION=2025-06-26
FANVUE_API_BASE=https://api.fanvue.com
FANVUE_AUTH_BASE=https://auth.fanvue.com
# UUID of the model on Fanvue (from Supabase models table)
FANVUE_MODEL_ID=
# Fanvue creator UUID for the model (found in Fanvue URL or via API)
FANVUE_CREATOR_UUID=
# JSON map of IG handles to avatar persona IDs (optional attribution)
FANVUE_IG_MAP={}

# ─── ONLYFANS (if PLATFORM_MODE is "onlyfans" or "both") ───────
# Sign up at: https://app.onlyfansapi.com
OFAPI_KEY=
OFAPI_ACCOUNT_ID=
OFAPI_WEBHOOK_SECRET=
OFAPI_BASE=https://app.onlyfansapi.com
# UUID of the model (from Supabase models table)
OF_MODEL_ID=
# OnlyFans user ID of the model account (for /register_of media pull)
OF_MODEL_CHAT_ID=
# JSON map of IG handles to avatar persona IDs
OF_IG_MAP={}

# ─── REDIS (runs in Docker — no changes needed) ─────────────────
REDIS_URL=redis://redis:6379/0

# ─── SENTRY (Optional — free tier) ──────────────────────────────
# Create project at: https://sentry.io (choose Python)
SENTRY_DSN=
ENVIRONMENT=production

# ─── TUNING (optional — have defaults) ──────────────────────────
# Settle window: wait for burst messages before replying
MESSAGE_SETTLE_INITIAL_SECONDS=8
MESSAGE_SETTLE_EXTENSION_SECONDS=5
MESSAGE_SETTLE_MAX_SECONDS=30

# PPV cleanup: auto-delete unpaid PPVs after this many hours
PPV_ABANDONMENT_HOURS=6
PPV_SWEEP_INTERVAL_SECONDS=600

# Custom order re-alert cadence
CUSTOM_REALERT_INTERVAL_SECONDS=3600
